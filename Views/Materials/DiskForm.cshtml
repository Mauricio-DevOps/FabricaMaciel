@model Fabrica.Models.ViewModels.Materials.DiskFormViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="materials-shell">
    <div class="materials-page-header">
        <div>
            <a asp-action="Index" asp-route-tab="discos" class="materials-back-link">← Voltar para Materiais</a>
            <h1>@Model.Title</h1>
            <p>Informe raio e grossura. Se o disco for de alumínio, o sistema pode calcular o peso automaticamente.</p>
        </div>
    </div>

    <div class="materials-form-layout">
        <article class="materials-card materials-form-card">
            <form asp-action="@(Model.Id.HasValue ? "EditDisk" : "CreateDisk")" method="post" class="materials-form" id="disk-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                @if (Model.Id.HasValue)
                {
                    <input type="hidden" asp-for="Id" />
                }

                <div class="materials-grid">
                    <div class="materials-field">
                        <label asp-for="RaioMm" class="form-label"></label>
                        <div class="materials-input-group">
                            <input asp-for="RaioMm" class="form-control" type="number" min="1" step="1" />
                            <span class="materials-input-suffix">mm</span>
                        </div>
                        <span asp-validation-for="RaioMm" class="text-danger"></span>
                    </div>

                    <div class="materials-field">
                        <label asp-for="GrossuraMm" class="form-label"></label>
                        <div class="materials-input-group">
                            <input asp-for="GrossuraMm" class="form-control" type="number" step="0.01" inputmode="decimal" />
                            <span class="materials-input-suffix">mm</span>
                        </div>
                        <span asp-validation-for="GrossuraMm" class="text-danger"></span>
                    </div>
                </div>

                <label class="materials-checkbox">
                    <input asp-for="CalcularPesoAutomaticamente" />
                    <span>Calcular automaticamente para alumínio</span>
                </label>

                <div class="materials-field">
                    <label asp-for="PesoUnitarioKg" class="form-label"></label>
                    <div class="materials-input-group">
                        <input asp-for="PesoUnitarioKg" class="form-control" type="number" step="0.0001" inputmode="decimal" />
                        <span class="materials-input-suffix">kg</span>
                    </div>
                    <div class="form-text" id="disk-weight-help">
                        O cálculo usa densidade do alumínio de 2,70 g/cm³.
                    </div>
                    <span asp-validation-for="PesoUnitarioKg" class="text-danger"></span>
                </div>

                <div class="materials-preview-card">
                    <div>
                        <span class="materials-preview-label">Medida</span>
                        <strong id="medida-preview">@Model.MedidaPreview</strong>
                    </div>
                    <div>
                        <span class="materials-preview-label">Peso estimado</span>
                        <strong id="peso-preview">@Model.PesoUnitarioKgEstimado.ToString("0.0000") kg</strong>
                    </div>
                </div>

                <div class="materials-form-actions">
                    <button type="submit" class="btn btn-primary btn-lg">Salvar disco</button>
                    <a asp-action="Index" asp-route-tab="discos" class="btn btn-outline-secondary btn-lg">Cancelar</a>
                </div>
            </form>
        </article>

        <aside class="materials-card materials-side-card">
            <span class="materials-kicker">Cálculo automático</span>
            <h2>Disco de alumínio</h2>
            <p class="mb-3">Peso estimado com a fórmula do cilindro maciço:</p>
            <code class="materials-formula">peso = π × raio² × grossura × densidade</code>
            <p class="mt-3 mb-0">Se quiser informar um peso manual, desmarque a opção de cálculo automático.</p>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const density = 2.7;
            const raio = document.getElementById('RaioMm');
            const grossura = document.getElementById('GrossuraMm');
            const peso = document.getElementById('PesoUnitarioKg');
            const auto = document.getElementById('CalcularPesoAutomaticamente');
            const medidaPreview = document.getElementById('medida-preview');
            const pesoPreview = document.getElementById('peso-preview');
            const help = document.getElementById('disk-weight-help');

            if (!raio || !grossura || !peso || !auto || !medidaPreview || !pesoPreview || !help) return;

            const calculateWeightKg = () => {
                const radiusMm = Number.parseFloat(raio.value.replace(',', '.'));
                const thicknessMm = Number.parseFloat(grossura.value.replace(',', '.'));

                if (!Number.isFinite(radiusMm) || !Number.isFinite(thicknessMm) || radiusMm <= 0 || thicknessMm <= 0) {
                    return 0;
                }

                const radiusCm = radiusMm / 10;
                const thicknessCm = thicknessMm / 10;
                const volumeCm3 = Math.PI * radiusCm * radiusCm * thicknessCm;
                const weightGrams = volumeCm3 * density;
                return weightGrams / 1000;
            };

            const updatePreview = () => {
                const raioValue = raio.value || '0';
                const grossuraValue = grossura.value || '0';
                const estimatedWeight = calculateWeightKg();

                medidaPreview.textContent = `${raioValue} x ${grossuraValue}`;
                pesoPreview.textContent = `${estimatedWeight.toFixed(4)} kg`;

                if (auto.checked) {
                    peso.value = estimatedWeight > 0 ? estimatedWeight.toFixed(4) : '';
                    peso.setAttribute('readonly', 'readonly');
                    help.textContent = 'Peso preenchido automaticamente com base na densidade do alumínio (2,70 g/cm³).';
                } else {
                    peso.removeAttribute('readonly');
                    help.textContent = 'Informe manualmente o peso unitário em quilogramas.';
                }
            };

            raio.addEventListener('input', updatePreview);
            grossura.addEventListener('input', updatePreview);
            auto.addEventListener('change', updatePreview);
            updatePreview();
        })();
    </script>
}
